{
  "name": "skill-manager",
  "version": "1.0.0",
  "description": "可视化管理 Claude Code Skills 的桌面应用",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:ts": "npm run build:main && npm run build:renderer",
    "start": "npm run build:ts && electron .",
    "dev": "npm run build:ts && electron .",
    "pack": "npm run build:ts && electron-builder --dir",
    "dist": "npm run build:ts && electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.skillmanager.app",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*"
    ]
  }
}
